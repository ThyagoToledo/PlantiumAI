# PlantiuIA — Configurações de Ambiente
# Copie para .env e preencha com suas chaves

# --- Modo de IA ---
# Opções: local_only | api_only | hybrid_prefer_api | hybrid_prefer_local | smart_failover
AI_MODE=smart_failover

# --- Modelo Local GGUF ---
LOCAL_MODEL_PATH=
LOCAL_MODEL_THREADS=0
LOCAL_MODEL_CONTEXT=4096
LOCAL_MODEL_GPU_LAYERS=0

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision
OLLAMA_TEXT_MODEL=llama3.2

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- BlackBox AI ---
BLACKBOX_API_KEY=
BLACKBOX_MODEL=blackboxai

# --- MiniMax (2.7 / MiniMax-Text-01) ---
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01

# --- Meteorologia ---
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=São Paulo
OPENWEATHER_COUNTRY=BR

# --- Servidor ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false

# --- Circuit Breaker ---
CB_FAILURE_THRESHOLD=3
CB_RECOVERY_TIMEOUT=60
